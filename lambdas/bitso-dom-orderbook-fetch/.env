S3_BUCKET=bitso-orderbook
DDB_TABLE=bitso_snapshot_state
MAX_RETRIES=2
RETRY_BACKOFF_MS=150
WRITE_GZIP=true
DDB_STREAM=dom
HTTP_TIMEOUT_SEC=2.0
BOOKS=btc_usd,eth_usd,sol_usd
PARTITIONED_KEYS=true
DDB_STRICT=false
JSON_PREFIX=bitso_dom_snapshots/
DDB_BOOKS_ALLOWLIST=btc_usd,eth_usd,sol_usd
ORDERBOOK_PCT=0.05
